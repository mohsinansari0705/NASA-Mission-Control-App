{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "esnext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "declaration": true,
    "rootDir": "./",
    "outDir": "./dist",
    "types": [
      "node",
      "express"
    ]
  },
  "include": [
    "index.ts",
    "src/**/**/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
